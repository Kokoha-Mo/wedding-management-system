spring.application.name=wedding-management-system

spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=jdbc:mysql://localhost:3306/your_db_name?serverTimezone=Asia/Taipei
spring.datasource.username=root
spring.datasource.password=password123

spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
spring.jpa.hibernate.ddl-auto=update

spring.servlet.encoding.charset=UTF-8
spring.servlet.encoding.enabled=true
spring.servlet.encoding.force=true

# 檔案上傳設定
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
# 告訴 DevTools 不要因為 uploads 資料夾內的檔案變更而重新啟動/刷新
spring.devtools.restart.exclude=static/uploads/**,public/uploads/**,uploads/**

# Gmail SMTP 設定
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=joy9632147joy@gmail.com
spring.mail.password=xwzzwwsifnlraxdw
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
